generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RecurrenceType {
  MONTHLY
  EVERY_TWO_MONTHS
  QUARTERLY
  SEMI_YEARLY
  YEARLY
  WEEKLY
  EVERY_FOUR_WEEKS
  ONE_TIME
  IRREGULAR
  CUSTOM
  UNCLEAR
}

enum RecurrenceClass {
  RECURRING
  ONE_TIME
  UNCLEAR
}

enum LimitationType {
  UNLIMITED
  UNTIL_DATE
  NUMBER_OF_PAYMENTS
  UNKNOWN
  NOT_APPLICABLE
}

enum LifecycleStatus {
  ACTIVE
  INACTIVE
  ENDED
}

enum ConfidenceStatus {
  SAFE
  ESTIMATED
  AUTO_DETECTED
  MANUALLY_CONFIRMED
  NEEDS_REVIEW
  OBSOLETE
  REPLACED
  IGNORED
}

enum SourceType {
  MANUAL
  IMPORT
  AI
  SYSTEM
}

enum PaymentType {
  NORMAL
  PREPAYMENT
  INSTALLMENT
  REFUND
  CORRECTION
  REVERSAL
  INCOME
  CASH_WITHDRAWAL
  TRANSFER
  UNKNOWN
}

enum PaymentStatus {
  PLANNED
  BOOKED
  RECONCILED
  NEEDS_REVIEW
  IGNORED
}

enum ImportSuggestionStatus {
  OPEN
  ACCEPTED
  REJECTED
  POSTPONED
  DUPLICATE
  EDITED
}

enum ImportStatus {
  NEW
  IMPORTED
  NEEDS_REVIEW
  LINKED
  IGNORED
  DUPLICATE
}

enum ReportStatus {
  SUCCESS
  FAILED
}

enum ImportRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum ImportRuleStatus {
  ACTIVE
  PAUSED
  NEEDS_REVIEW
}

enum ImportActionType {
  LINK_PURCHASE_DOCUMENT_TO_COST_POSITION
  SET_PURCHASE_DOCUMENT_CATEGORY
  SET_PURCHASE_DOCUMENT_RECURRENCE
  CREATE_COST_POSITION_FROM_PURCHASE_DOCUMENT
  LINK_PAYMENT_TO_COST_POSITION
  CONFIRM_PAYMENT_MATCH
  MARK_DOCUMENT_DUPLICATE
  IGNORE_DOCUMENT
  CREATE_OR_UPDATE_IMPORT_RULE
}

enum ImportDecisionStatus {
  PREVIEWED
  AUTO_APPLIED
  APPLIED
  NEEDS_REVIEW
  BLOCKED
  REJECTED
  SUPERSEDED
}

enum AutomationActor {
  CODEX
  SYSTEM
  USER
}

model CostPosition {
  id                   String             @id @default(cuid())
  title                String
  providerId           String?
  categoryId           String?
  householdScopeId     String?
  amountCents          Int
  currency             String             @default("EUR")
  recurrenceType       RecurrenceType      @default(UNCLEAR)
  recurrenceCustomRule String?
  recurrenceClass      RecurrenceClass     @default(UNCLEAR)
  limitationType       LimitationType      @default(UNKNOWN)
  paymentCountLimit    Int?
  startDate            DateTime?
  endDate              DateTime?
  nextDueDate          DateTime?
  paymentMethod        String?
  status               LifecycleStatus     @default(ACTIVE)
  confidenceStatus     ConfidenceStatus    @default(NEEDS_REVIEW)
  monthlyValueCents    Int                 @default(0)
  yearlyValueCents     Int                 @default(0)
  sourceType           SourceType          @default(MANUAL)
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  provider             Provider?           @relation(fields: [providerId], references: [id])
  category             Category?           @relation(fields: [categoryId], references: [id])
  householdScope       HouseholdScope?     @relation(fields: [householdScopeId], references: [id])
  payments             Payment[]
  documents            Document[]
  importSuggestions    ImportSuggestion[]
  versions             CostPositionVersion[]
  purchaseDocuments    PurchaseDocument[]

  @@index([status])
  @@index([recurrenceClass])
  @@index([recurrenceType])
  @@index([limitationType])
  @@index([nextDueDate])
}

model CostPositionVersion {
  id                String          @id @default(cuid())
  costPositionId    String
  validFrom         DateTime
  validTo           DateTime?
  amountCents       Int
  recurrenceType    RecurrenceType
  recurrenceClass   RecurrenceClass
  limitationType    LimitationType
  monthlyValueCents Int
  yearlyValueCents  Int
  notes             String?
  sourceType        SourceType      @default(MANUAL)
  createdAt         DateTime        @default(now())

  costPosition      CostPosition    @relation(fields: [costPositionId], references: [id], onDelete: Cascade)

  @@index([costPositionId, validFrom])
}

model Payment {
  id               String           @id @default(cuid())
  costPositionId   String?
  providerId       String?
  date             DateTime
  amountCents      Int
  currency         String           @default("EUR")
  paymentType      PaymentType      @default(NORMAL)
  description      String?
  bankAccountRef   String?
  sourceDocumentId String?
  status           PaymentStatus    @default(BOOKED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  costPosition     CostPosition?    @relation(fields: [costPositionId], references: [id])
  provider         Provider?        @relation(fields: [providerId], references: [id])
  sourceDocument   Document?        @relation("PaymentSourceDocument", fields: [sourceDocumentId], references: [id])
  linkedDocuments  Document[]       @relation("DocumentLinkedPayment")
  importSuggestions ImportSuggestion[]
  paymentMatches    PaymentMatch[]

  @@index([date])
  @@index([paymentType])
  @@index([status])
}

model Provider {
  id             String          @id @default(cuid())
  name           String
  normalizedName String          @unique
  aliasesJson    String          @default("[]")
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  costPositions  CostPosition[]
  payments       Payment[]
  documents      Document[]
  purchaseDocuments PurchaseDocument[]

  @@index([name])
}

model Category {
  id               String          @id @default(cuid())
  name             String
  parentCategoryId String?
  active           Boolean         @default(true)
  sortOrder        Int             @default(0)

  parent           Category?       @relation("CategoryChildren", fields: [parentCategoryId], references: [id])
  children         Category[]      @relation("CategoryChildren")
  costPositions    CostPosition[]
  purchaseDocuments PurchaseDocument[]
  purchaseItems     PurchaseItem[]

  @@unique([name, parentCategoryId])
  @@index([active, sortOrder])
}

model HouseholdScope {
  id            String         @id @default(cuid())
  name          String         @unique
  active        Boolean        @default(true)
  sortOrder     Int            @default(0)

  costPositions      CostPosition[]
  purchaseDocuments  PurchaseDocument[]
}

model Document {
  id                   String          @id @default(cuid())
  filePath             String
  fileName             String
  fileHash             String?
  documentType         String          @default("UNKLAR")
  documentGroup        String          @default("SONDERBELEG")
  documentDate         DateTime?
  providerId           String?
  amountCents          Int?
  currency             String          @default("EUR")
  extractionJson       String?
  importStatus         ImportStatus    @default(NEW)
  linkedCostPositionId String?
  linkedPaymentId      String?
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  provider             Provider?       @relation(fields: [providerId], references: [id])
  linkedCostPosition   CostPosition?   @relation(fields: [linkedCostPositionId], references: [id])
  linkedPayment        Payment?        @relation("DocumentLinkedPayment", fields: [linkedPaymentId], references: [id])
  sourcedPayments      Payment[]       @relation("PaymentSourceDocument")
  importSuggestions    ImportSuggestion[]
  purchaseDocuments    PurchaseDocument[]

  @@index([fileHash])
  @@index([importStatus])
  @@index([documentType])
}

model ImportSuggestion {
  id                   String                 @id @default(cuid())
  sourceDocumentId     String?
  suggestionType       String
  suggestedAction      String
  extractedJson        String
  confidence           Float                  @default(0)
  status               ImportSuggestionStatus @default(OPEN)
  linkedCostPositionId String?
  linkedPaymentId      String?
  notes                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  sourceDocument       Document?              @relation(fields: [sourceDocumentId], references: [id])
  linkedCostPosition   CostPosition?          @relation(fields: [linkedCostPositionId], references: [id])
  linkedPayment        Payment?               @relation(fields: [linkedPaymentId], references: [id])

  @@index([status])
  @@index([suggestionType])
}

model ImportRun {
  id            String          @id @default(cuid())
  source        String
  sourcePath    String?
  sourceHash    String?
  parserVersion String?
  actor         AutomationActor @default(SYSTEM)
  status        ImportRunStatus @default(RUNNING)
  parsedCount   Int             @default(0)
  createdCount  Int             @default(0)
  updatedCount  Int             @default(0)
  skippedCount  Int             @default(0)
  errorCount    Int             @default(0)
  summaryJson   String?
  message       String?
  startedAt     DateTime        @default(now())
  finishedAt    DateTime?

  decisions     ImportDecision[]

  @@index([source])
  @@index([status])
  @@index([startedAt])
}

model ImportRule {
  id                  String           @id @default(cuid())
  name                String
  description         String?
  source              String?
  action              ImportActionType
  status              ImportRuleStatus @default(ACTIVE)
  priority            Int              @default(100)
  confidenceThreshold Float            @default(0.86)
  sampleRate          Float            @default(0.1)
  matchJson           String           @default("{}")
  actionJson          String           @default("{}")
  targetEntityType    String?
  targetEntityId      String?
  applicationCount    Int              @default(0)
  errorCount          Int              @default(0)
  lastAppliedAt       DateTime?
  notes               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  decisions           ImportDecision[]

  @@index([status])
  @@index([source])
  @@index([action])
  @@index([priority])
}

model ImportDecision {
  id               String               @id @default(cuid())
  importRunId      String?
  importRuleId     String?
  action           ImportActionType
  status           ImportDecisionStatus @default(PREVIEWED)
  actor            AutomationActor      @default(CODEX)
  confidence       Float                @default(0)
  reason           String?
  sourceEntityType String?
  sourceEntityId   String?
  targetEntityType String?
  targetEntityId   String?
  sourceHash       String?
  sample           Boolean              @default(false)
  payloadJson      String               @default("{}")
  validationJson   String               @default("[]")
  resultJson       String?
  createdAt        DateTime             @default(now())
  appliedAt        DateTime?

  importRun        ImportRun?           @relation(fields: [importRunId], references: [id], onDelete: SetNull)
  importRule       ImportRule?          @relation(fields: [importRuleId], references: [id], onDelete: SetNull)
  auditLogs        AuditLog[]

  @@index([status])
  @@index([action])
  @@index([createdAt])
  @@index([sourceEntityType, sourceEntityId])
  @@index([targetEntityType, targetEntityId])
}

model PurchaseDocument {
  id                     String           @id @default(cuid())
  source                 String
  externalProviderName   String?
  externalDocumentNumber String?
  title                  String
  documentDate           DateTime?
  dueDate                DateTime?
  amountCents            Int              @default(0)
  currency               String           @default("EUR")
  status                 String           @default("NEEDS_REVIEW")
  recurrenceCandidate    String           @default("UNCLEAR")
  confidenceStatus       ConfidenceStatus @default(NEEDS_REVIEW)
  providerId             String?
  categoryId             String?
  householdScopeId       String?
  linkedCostPositionId   String?
  sourceDocumentId       String?
  rawJson                String?
  notes                  String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  provider               Provider?        @relation(fields: [providerId], references: [id])
  category               Category?        @relation(fields: [categoryId], references: [id])
  householdScope         HouseholdScope?  @relation(fields: [householdScopeId], references: [id])
  linkedCostPosition     CostPosition?    @relation(fields: [linkedCostPositionId], references: [id])
  sourceDocument         Document?        @relation(fields: [sourceDocumentId], references: [id])
  items                  PurchaseItem[]
  paymentMatches         PaymentMatch[]

  @@unique([source, externalDocumentNumber])
  @@index([source])
  @@index([documentDate])
  @@index([dueDate])
  @@index([status])
  @@index([confidenceStatus])
}

model PurchaseItem {
  id                  String           @id @default(cuid())
  purchaseDocumentId  String
  title               String
  quantity            Float?
  amountCents         Int?
  currency            String           @default("EUR")
  categoryId          String?
  recurrenceCandidate String           @default("UNCLEAR")
  rawJson             String?
  createdAt           DateTime         @default(now())

  purchaseDocument    PurchaseDocument @relation(fields: [purchaseDocumentId], references: [id], onDelete: Cascade)
  category            Category?        @relation(fields: [categoryId], references: [id])

  @@index([purchaseDocumentId])
  @@index([categoryId])
}

model PaymentMatch {
  id                  String           @id @default(cuid())
  purchaseDocumentId  String
  paymentId           String
  status              String           @default("PROPOSED")
  score               Float            @default(0)
  reason              String?
  amountDeltaCents    Int?
  dateDeltaDays       Int?
  notes               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  purchaseDocument    PurchaseDocument @relation(fields: [purchaseDocumentId], references: [id], onDelete: Cascade)
  payment             Payment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([purchaseDocumentId, paymentId])
  @@index([status])
  @@index([score])
}

model AuditLog {
  id               String          @id @default(cuid())
  importDecisionId String?
  entityType       String
  entityId         String
  action           String
  actor            AutomationActor @default(SYSTEM)
  beforeJson       String?
  afterJson        String?
  reason           String?
  sourceHash       String?
  createdAt        DateTime        @default(now())

  importDecision   ImportDecision? @relation(fields: [importDecisionId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([action])
  @@index([actor])
  @@index([createdAt])
}

model ReportRun {
  id          String       @id @default(cuid())
  reportType  String
  filePath    String
  format      String
  generatedAt DateTime     @default(now())
  status      ReportStatus @default(SUCCESS)
  message     String?

  @@index([generatedAt])
  @@index([reportType])
}

model BackupRun {
  id          String       @id @default(cuid())
  backupType  String
  filePath    String
  generatedAt DateTime     @default(now())
  status      ReportStatus @default(SUCCESS)
  message     String?

  @@index([generatedAt])
  @@index([backupType])
}

model AppSetting {
  key       String   @id
  value     String
  label     String?
  updatedAt DateTime @updatedAt
}
