{
  "name": "haushaltskosten",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup:runtime": "node scripts/setup-runtime.mjs",
    "postinstall": "npm run setup:runtime && prisma generate",
    "app:prepare": "npm run setup:runtime && prisma generate && npm run db:init && npm run db:seed",
    "predev": "npm run app:prepare",
    "dev": "next dev",
    "prebuild": "npm run setup:runtime && prisma generate",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "prisma:generate": "npm run setup:runtime && prisma generate",
    "db:init": "npm run setup:runtime && node scripts/init-db.mjs",
    "prisma:migrate": "npm run db:init",
    "prisma:deploy": "npm run db:init",
    "db:seed": "npm run setup:runtime && prisma db seed",
    "db:studio": "npm run setup:runtime && prisma studio"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "next": "16.2.4",
    "pdf-lib": "^1.17.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^16.4.7",
    "prisma": "6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "8.5.12"
  }
}
